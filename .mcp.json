{
	"mcpServers": {
		"svelte": {
			"type": "stdio",
			"command": "npx",
			"env": {},
			"args": ["-y", "@sveltejs/mcp"]
		},
		"playwright": {
			"type": "stdio",
			"command": "npx",
			"env": {},
			"args": [
				"-y",
				"@playwright/mcp",
				"--browser",
				"chromium",
				"--executable-path",
				"/run/current-system/sw/bin/brave"
			]
		}
	}
}
